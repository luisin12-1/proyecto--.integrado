' Jorge Reyes, Luis Polanco, Gerardo Torres.
' =========================================================
' 1. VARIABLES GLOBALES E INICIALIZACIÓN
' =========================================================
Foco = "a"
ValA = ""
ValB = ""
ValC = ""

' Variables de la calculadora tradicional
operadorSuma = 0
operadorResta = 0
operadorMultiplica = 0
operadorDivide = 0
primerNumero = 0

' Control de estado para el módulo universal
panelVisible = "Falso"
puedeEscribir = "Falso" 

' Variables del módulo de Sistema 2x2
paso = 1
valorActual = ""
sis_a = 0
sis_b = 0
sis_c = 0
sis_d = 0
sis_e = 0
sis_f = 0

' Variable del módulo de Energía Original
panelEnergiaIniciado = "Falso"
ModoEnergia = "Calcular" ' Modos posibles: Calcular, DespejarM, DespejarV, DespejarK, DespejarX

' Cargar la calculadora original al arrancar
MostrarCalculadoraOriginal()

' =========================================================
' 2. VENTANA DE LA CALCULADORA ORIGINAL
' =========================================================
Sub MostrarCalculadoraOriginal
  GraphicsWindow.Clear()
  GraphicsWindow.Title = "Calculadora Original"
  GraphicsWindow.Width = 355
  GraphicsWindow.Height = 600 ' Ajustado para dar espacio excelente a ambos botones
  GraphicsWindow.CanResize = "no"
  GraphicsWindow.BackgroundColor = "LightGray"

  ' Formas originales
  GraphicsWindow.BrushColor = "green"
  GraphicsWindow.FillRectangle (40, 45, 260, 65)

  GraphicsWindow.BrushColor = "gray"
  GraphicsWindow.FillRectangle (17, 130, 320, 340)

  ' Borde del teclado
  GraphicsWindow.PenColor = "blue"
  GraphicsWindow.DrawRectangle (17, 130, 320, 340)

  ' Borde exterior
  GraphicsWindow.DrawRectangle (10, 15, 335, 550)

  ' Visor de número
  caja = Controls.AddTextBox(55, 55)
  Controls.SetSize (caja, 230, 40)

  ' Boton de cuadratica (Ecua2)
  GraphicsWindow.BrushColor = "#A45A52"
  BtnCambiarModo = Controls.AddButton("Ecua2", 208, 420)
  Controls.SetSize(BtnCambiarModo, 60, 45)

  ' Boton para abrir la Calculadora Universal de Ecuaciones
  GraphicsWindow.BrushColor = "DarkBlue"
  BtnAbrirUniversal = Controls.AddButton("Ecualin", 146, 420)
  Controls.SetSize(BtnAbrirUniversal, 60, 45)

  ' Boton para abrir el Sistema de Ecuaciones 2x2
  GraphicsWindow.BrushColor = "#E28743"
  BtnAbrirSist2x2 = Controls.AddButton("Sist2x2", 208, 270)
  Controls.SetSize(BtnAbrirSist2x2, 60, 45)

  ' Boton para abrir el Módulo de Energía ORIGINAL (Verde)
  GraphicsWindow.BrushColor = "#2E8B57"
  BtnAbrirEnergia = Controls.AddButton("Energía", 23, 223)
  Controls.SetSize(BtnAbrirEnergia, 308, 45)

  ' Boton para abrir el NUEVO Módulo de Energía v2 (Gris Oscuro)
  GraphicsWindow.BrushColor = "#333333"
  GraphicsWindow.FontSize = 12
  BtnAbrirEnergiaV2 = Controls.AddButton("Energía v2 (Consola)", 23  , 160)
  Controls.SetSize(BtnAbrirEnergiaV2, 308, 45)

  ' Color botones normales de la calculadora
  GraphicsWindow.BrushColor = "blue"
  GraphicsWindow.FontSize = 12

  ' Teclado numérico original
  uno = Controls.AddButton("1", 23, 370)
  Controls.SetSize (uno, 60, 45)
  dos = Controls.AddButton("2", 85, 370)
  Controls.SetSize (dos, 60, 45)
  tres = Controls.AddButton("3", 146, 370)
  Controls.SetSize (tres, 60, 45)
  cuatro = Controls.AddButton("4", 23, 320)
  Controls.SetSize (cuatro, 60, 45)
  cinco = Controls.AddButton("5", 85, 320)
  Controls.SetSize (cinco, 60, 45)
  seis = Controls.AddButton("6", 146, 320)
  Controls.SetSize (seis, 60, 45)
  siete = Controls.AddButton("7", 23, 270)
  Controls.SetSize (siete, 60, 45)
  ocho = Controls.AddButton("8", 85, 270)
  Controls.SetSize (ocho, 60, 45)
  nueve = Controls.AddButton("9", 208, 320)
  Controls.SetSize (nueve, 60, 45)
  cero = Controls.AddButton("0", 23, 420)
  Controls.SetSize (cero, 60, 45)

  punto = Controls.AddButton(".", 85, 420)
  Controls.SetSize (punto, 60, 45)

  sumar = Controls.AddButton("+", 208, 370)
  Controls.SetSize (sumar, 60, 45)
  restar = Controls.AddButton("-", 270, 370)
  Controls.SetSize (restar, 60, 45)
  
  multiplicar = Controls.AddButton ("x", 270, 270)
  Controls.SetSize (multiplicar, 60, 45)
  dividir = Controls.AddButton(" / ", 270, 320)
  Controls.SetSize (dividir, 60, 45)
  
  igual = Controls.AddButton("=", 270, 420)
  Controls.SetSize (igual, 60, 45)
  limpiar = Controls.AddButton("AC", 146, 270)
  Controls.SetSize (limpiar, 60, 45)

  ' Asignar el evento para esta ventana
  Controls.ButtonClicked = AlPresionarOriginal
EndSub

Sub AlPresionarOriginal
  ultimo_boton = Controls.LastClickedButton
  
  If ultimo_boton = BtnCambiarModo Then
    MostrarVentanaCuadratica()
  EndIf
  
  If ultimo_boton = BtnAbrirUniversal Then
    MostrarVentanaUniversal()
  EndIf

  If ultimo_boton = BtnAbrirSist2x2 Then
    paso = 1
    valorActual = ""
    sis_a = 0
    sis_b = 0
    sis_c = 0
    sis_d = 0
    sis_e = 0
    sis_f = 0
    InicializarCalculadoraSist2x2()
  EndIf

  ' ACTIVA ENERGÍA ORIGINAL
  If ultimo_boton = BtnAbrirEnergia Then
    panelEnergiaIniciado = "Falso"
    ModoEnergia = "Calcular"
    MostrarVentanaEnergia()
  EndIf

  ' ACTIVA ENERGÍA V2 (De la ventana de texto)
  If ultimo_boton = BtnAbrirEnergiaV2 Then
    EjecutarEnergiaV2()
  EndIf
  
  ' Teclado estándar
  If ultimo_boton = uno Then
    contenido_caja = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, Text.Append(contenido_caja, "1"))
  ElseIf ultimo_boton = dos then
    contenido_caja = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, Text.Append(contenido_caja, "2"))
  ElseIf ultimo_boton = tres then
    contenido_caja = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, Text.Append(contenido_caja, "3"))
  ElseIf ultimo_boton = cuatro then
    contenido_caja = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, Text.Append(contenido_caja, "4"))
  ElseIf ultimo_boton = cinco then
    contenido_caja = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, Text.Append(contenido_caja, "5"))
  ElseIf ultimo_boton = seis then
    contenido_caja = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, Text.Append(contenido_caja, "6"))
  ElseIf ultimo_boton = siete then
    contenido_caja = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, Text.Append(contenido_caja, "7"))
  ElseIf ultimo_boton = ocho then
    contenido_caja = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, Text.Append(contenido_caja, "8"))
  ElseIf ultimo_boton = nueve then
    contenido_caja = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, Text.Append(contenido_caja, "9"))
  ElseIf ultimo_boton = cero then
    contenido_caja = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, Text.Append(contenido_caja, "0"))
  ElseIf ultimo_boton = punto then
    contenido_caja = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, Text.Append(contenido_caja, "."))
  ElseIf ultimo_boton = limpiar then
    Controls.SetTextBoxText(caja, "")
  ElseIf ultimo_boton = sumar then
    primerNumero = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, "")
    operadorSuma = 1
  ElseIf ultimo_boton = restar then
    primerNumero = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, "")
    operadorResta = 1
  ElseIf ultimo_boton = multiplicar then
    primerNumero = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, "")
    operadorMultiplica = 1
  ElseIf ultimo_boton = dividir then
    primerNumero = Controls.GetTextBoxText(caja)
    Controls.SetTextBoxText(caja, "")
    operadorDivide = 1
  ElseIf ultimo_boton = igual then
    segundoNumero = Controls.GetTextBoxText(caja)
    If operadorSuma = 1 Then
      resultado = primerNumero + segundoNumero
      operadorSuma = 0
    ElseIf operadorResta = 1 Then
      resultado = primerNumero - segundoNumero
      operadorResta = 0
    ElseIf operadorMultiplica = 1 Then
      resultado = primerNumero * segundoNumero
      operadorMultiplica = 0
    ElseIf operadorDivide = 1 Then
      If segundoNumero <> 0 Then
        resultado = primerNumero / segundoNumero
      Else
        resultado = "Error"
      EndIf
      operadorDivide = 0
    EndIf
    Controls.SetTextBoxText(caja, resultado)
  EndIf
EndSub

' =========================================================
' 3. MÓDULO DE ENERGÍA ORIGINAL (RESTAURADO COMPLETAMENTE)
' =========================================================
Sub MostrarVentanaEnergia
  GraphicsWindow.Clear()
  GraphicsWindow.Title = "Módulo de Conservación de Energía"
  GraphicsWindow.Width = 480
  GraphicsWindow.Height = 440
  GraphicsWindow.BackgroundColor = "#F0F4F8"

  ' Panel superior informativo
  GraphicsWindow.BrushColor = "#2E8B57"
  GraphicsWindow.FillRectangle(15, 15, 450, 60)
  GraphicsWindow.BrushColor = "White"
  GraphicsWindow.FontName = "Arial"
  GraphicsWindow.FontSize = 14
  GraphicsWindow.FontBold = "True"
  GraphicsWindow.DrawText(25, 23, "CÁLCULO DE ENERGÍA MECÁNICA TOTAL")
  GraphicsWindow.FontSize = 11
  GraphicsWindow.FontBold = "False"
  GraphicsWindow.DrawText(25, 45, "Modo actual: " + ModoEnergia + " | EM = Ec + Eg + Ee")

  ' Etiquetas y Cuadros de entrada de Datos
  GraphicsWindow.BrushColor = "Black"
  GraphicsWindow.FontSize = 12
  
  GraphicsWindow.DrawText(30, 100, "Masa (m) [kg]:")
  txtMasa = Controls.AddTextBox(180, 95)
  Controls.SetSize(txtMasa, 80, 25)

  GraphicsWindow.DrawText(30, 135, "Velocidad (v) [m/s]:")
  txtVel = Controls.AddTextBox(180, 130)
  Controls.SetSize(txtVel, 80, 25)

  GraphicsWindow.DrawText(30, 170, "Altura (h) [m]:")
  txtAlt = Controls.AddTextBox(180, 165)
  Controls.SetSize(txtAlt, 80, 25)

  GraphicsWindow.DrawText(30, 205, "Constante K [N/m]:")
  txtK = Controls.AddTextBox(180, 200)
  Controls.SetSize(txtK, 80, 25)

  GraphicsWindow.DrawText(30, 240, "Deformación X [m]:")
  txtX = Controls.AddTextBox(180, 235)
  Controls.SetSize(txtX, 80, 25)

  GraphicsWindow.DrawText(30, 275, "E. Objetivo [J] (Opcional):")
  txtEObj = Controls.AddTextBox(180, 270)
  Controls.SetSize(txtEObj, 80, 25)

  ' Botones de Cambio de Modo de Despeje Lateral
  GraphicsWindow.BrushColor = "#4682B4"
  btnModoCalc = Controls.AddButton("Modo: Calcular EM", 280, 95)
  btnModoM = Controls.AddButton("Despejar Masa (m)", 280, 130)
  btnModoV = Controls.AddButton("Despejar Vel. (v)", 280, 165)
  btnModoK = Controls.AddButton("Despejar Const. K", 280, 200)
  btnModoX = Controls.AddButton("Despejar Def. X", 280, 235)
  
  Controls.SetSize(btnModoCalc, 170, 28)
  Controls.SetSize(btnModoM, 170, 28)
  Controls.SetSize(btnModoV, 170, 28)
  Controls.SetSize(btnModoK, 170, 28)
  Controls.SetSize(btnModoX, 170, 28)

  ' Botones inferiores de Acción
  GraphicsWindow.BrushColor = "#2E8B57"
  btnCalcularEnergia = Controls.AddButton("PROCESAR CÁLCULO", 30, 330)
  Controls.SetSize(btnCalcularEnergia, 230, 40)

  GraphicsWindow.BrushColor = "gray"
  btnVolverDeEnergia = Controls.AddButton("VOLVER AL MENÚ", 280, 330)
  Controls.SetSize(btnVolverDeEnergia, 170, 40)

  panelEnergiaIniciado = "Verdadero"
  Controls.ButtonClicked = AlPresionarEnergiaOriginal
EndSub

Sub AlPresionarEnergiaOriginal
  btnPresionado = Controls.LastClickedButton

  If btnPresionado = btnVolverDeEnergia Then
    MostrarCalculadoraOriginal()
  EndIf

  ' Manejo de los cambios de Modo
  If btnPresionado = btnModoCalc Then
    ModoEnergia = "Calcular"
    MostrarVentanaEnergia()
  ElseIf btnPresionado = btnModoM Then
    ModoEnergia = "DespejarM"
    MostrarVentanaEnergia()
  ElseIf btnPresionado = btnModoV Then
    ModoEnergia = "DespejarV"
    MostrarVentanaEnergia()
  ElseIf btnPresionado = btnModoK Then
    ModoEnergia = "DespejarK"
    MostrarVentanaEnergia()
  ElseIf btnPresionado = btnModoX Then
    ModoEnergia = "DespejarX"
    MostrarVentanaEnergia()
  EndIf

  ' Procesar Fórmulas Matemáticas según el Modo Seleccionado
  If btnPresionado = btnCalcularEnergia Then
    m = Controls.GetTextBoxText(txtMasa)
    v = Controls.GetTextBoxText(txtVel)
    h = Controls.GetTextBoxText(txtAlt)
    k = Controls.GetTextBoxText(txtK)
    x = Controls.GetTextBoxText(txtX)
    E_objetivo = Controls.GetTextBoxText(txtEObj)
    g = 9.81

    ' Validaciones de nulos por defecto
    If m = "" Then
      m = 0
    EndIf
    If v = "" Then
      v = 0
    EndIf
    If h = "" Then
      h = 0
    EndIf
    If k = "" Then
      k = 0
    EndIf
    If x = "" Then
      x = 0
    EndIf
    If E_objetivo = "" Then
      E_objetivo = 0
    EndIf

    If ModoEnergia = "Calcular" Then
      Ec = 0.5 * m * Math.Power(v, 2)
      Eg = m * g * h
      Ee = 0.5 * k * Math.Power(x, 2)
      Em = Ec + Eg + Ee

      Ec = Math.Round(Ec * 100) / 100
      Eg = Math.Round(Eg * 100) / 100
      Ee = Math.Round(Ee * 100) / 100
      Em = Math.Round(Em * 100) / 100

      GraphicsWindow.ShowMessage("Resultados obtenidos:" + Text.GetCharacter(10) + "E. Cinética (Ec): " + Ec + " J" + Text.GetCharacter(10) + "E. Potencial Grav (Eg): " + Eg + " J" + Text.GetCharacter(10) + "E. Elástica (Ee): " + Ee + " J" + Text.GetCharacter(10) + "---------------------------" + Text.GetCharacter(10) + "Energía Mecánica Total: " + Em + " Joules", "Balance Energético")
    
    ElseIf ModoEnergia = "DespejarM" Then
      Denominador = (0.5 * Math.Power(v, 2)) + (g * h)
      If Denominador = 0 Then
        GraphicsWindow.ShowMessage("Error: División entre cero. Verifique velocidad o altura.", "Error de Despeje")
      Else
        Ee = 0.5 * k * Math.Power(x, 2)
        m_despejada = (E_objetivo - Ee) / Denominador ' ¡CORREGIDO AQUÍ! (Era Eee)
        m_despejada = Math.Round(m_despejada * 100) / 100
        Controls.SetTextBoxText(txtMasa, m_despejada)
        GraphicsWindow.ShowMessage("Masa encontrada: " + m_despejada + " kg", "Conservación de Energía")
      EndIf

    ElseIf ModoEnergia = "DespejarV" Then
      If m <= 0 Then
        GraphicsWindow.ShowMessage("Error: Se requiere una masa mayor a 0 para despejar v.", "Falta de Datos")
      Else
        Eg = m * g * h
        Ee = 0.5 * k * Math.Power(x, 2)
        ArgumentoV = (2 * (E_objetivo - Eg - Ee)) / m
        If ArgumentoV < 0 Then
          GraphicsWindow.ShowMessage("Error: La energía objetivo es insuficiente (Raíz negativa).", "Error Físico")
        Else
          v_despejada = Math.SquareRoot(ArgumentoV)
          v_despejada = Math.Round(v_despejada * 100) / 100
          Controls.SetTextBoxText(txtVel, v_despejada)
          GraphicsWindow.ShowMessage("Velocidad encontrada: " + v_despejada + " m/s", "Conservación de Energía")
        EndIf
      EndIf

    ElseIf ModoEnergia = "DespejarK" Then
      If x = 0 Then
        GraphicsWindow.ShowMessage("Error: La deformación X no puede ser 0 para despejar K.", "Falta de Datos")
      Else
        Ec = 0.5 * m * Math.Power(v, 2)
        Eg = m * g * h
        k_despejada = (2 * (E_objetivo - Ec - Eg)) / Math.Power(x, 2)
        k_despejada = Math.Round(k_despejada * 100) / 100
        Controls.SetTextBoxText(txtK, k_despejada)
        GraphicsWindow.ShowMessage("Constante elástica K: " + k_despejada + " N/m", "Conservación de Energía")
      EndIf

    ElseIf ModoEnergia = "DespejarX" Then
      If k <= 0 Then
        GraphicsWindow.ShowMessage("Error: Requiere constante K mayor a cero.", "Falta de Datos")
      Else
        Ec = 0.5 * m * Math.Power(v, 2)
        Eg = m * g * h
        ArgumentoX = (2 * (E_objetivo - Ec - Eg)) / k
        If ArgumentoX < 0 Then
          GraphicsWindow.ShowMessage("Error: Energía insuficiente para deformar el resorte.", "Error Físico")
        Else
          x_despejada = Math.SquareRoot(ArgumentoX)
          x_despejada = Math.Round(x_despejada * 100) / 100
          Controls.SetTextBoxText(txtX, x_despejada)
          GraphicsWindow.ShowMessage("Deformación X encontrada: " + x_despejada + " m", "Conservación de Energía")
        EndIf
      EndIf
    EndIf
  EndIf
EndSub

' =========================================================
' 4. NUEVA SUBRUTINA: MÓDULO DE ENERGÍA MECÁNICA V2
' =========================================================
Sub EjecutarEnergiaV2
  GraphicsWindow.Hide()
  TextWindow.Title = "Datos del Sistema Físico"
  TextWindow.Clear()
  
  TextWindow.ForegroundColor = "Cyan"
  TextWindow.WriteLine("==================================================")
  TextWindow.WriteLine("  CALCULADORA DE ENERGÍA Y TRABAJO DE FRICCIÓN    ")
  TextWindow.WriteLine("==================================================")
  TextWindow.ForegroundColor = "White"
  TextWindow.WriteLine("")
  TextWindow.WriteLine("Escribe el valor numérico de cada variable.")
  TextWindow.WriteLine("Si buscas una incógnita, escribe '?'. Si pones todo, calculará el balance total.")
  TextWindow.WriteLine("")
  
  g = 9.81
  
  ' --- RECOLECTAR DATOS ---
  TextWindow.Write("Masa (m) en kg: ")
  m_txt = TextWindow.Read()
  TextWindow.Write("Velocidad inicial (vi) en m/s: ")
  vi_txt = TextWindow.Read()
  TextWindow.Write("Altura inicial (hi) en metros: ")
  hi_txt = TextWindow.Read()
  TextWindow.Write("Deformación inicial del resorte (xi) en metros: ")
  xi_txt = TextWindow.Read()
  TextWindow.Write("Fuerza de Fricción (f) en Newtons: ")
  f_txt = TextWindow.Read()
  TextWindow.Write("Distancia de fricción (d) en metros: ")
  d_txt = TextWindow.Read()
  TextWindow.Write("Velocidad final (vf) en m/s: ")
  vf_txt = TextWindow.Read()
  TextWindow.Write("Altura final (hf) en metros: ")
  hf_txt = TextWindow.Read()
  TextWindow.Write("Deformación final del resorte (xf) en metros: ")
  xf_txt = TextWindow.Read()
  TextWindow.Write("Constante del resorte (k) en N/m: ")
  k_txt = TextWindow.Read()
  
  TextWindow.WriteLine("")
  TextWindow.ForegroundColor = "Yellow"
  TextWindow.WriteLine("--- RESULTADO ---")
  
  HayIncognita = "Falso"
  
  If (m_txt = "?") Then
    HayIncognita = "Verdadero"
    E_elastica_neta = (0.5 * k_txt * xf_txt * xf_txt) - (0.5 * k_txt * xi_txt * xi_txt)
    W_f = f_txt * d_txt
    Denominador = (0.5 * vi_txt * vi_txt) + (g * hi_txt) - (0.5 * vf_txt * vf_txt) - (g * hf_txt)
    m = (E_elastica_neta + W_f) / Denominador
    TextWindow.WriteLine("La Masa (m) es: " + m + " kg")
  ElseIf (vi_txt = "?") Then
    HayIncognita = "Verdadero"
    E_fin = (0.5 * m_txt * vf_txt * vf_txt) + (m_txt * g * hf_txt) + (0.5 * k_txt * xf_txt * xf_txt)
    W_f = f_txt * d_txt
    E_ini_restante = (m_txt * g * hi_txt) + (0.5 * k_txt * xi_txt * xi_txt)
    vi_cuadrado = (E_fin + W_f - E_ini_restante) / (0.5 * m_txt)
    vi = Math.SquareRoot(vi_cuadrado)
    TextWindow.WriteLine("La Velocidad inicial (vi) es: " + vi + " m/s")
  ElseIf (vf_txt = "?") Then
    HayIncognita = "Verdadero"
    E_ini = (0.5 * m_txt * vi_txt * vi_txt) + (m_txt * g * hi_txt) + (0.5 * k_txt * xi_txt * xi_txt)
    W_f = f_txt * d_txt
    E_fin_restante = (m_txt * g * hf_txt) + (0.5 * k_txt * xf_txt * xf_txt)
    vf_cuadrado = (E_ini - W_f - E_fin_restante) / (0.5 * m_txt)
    vf = Math.SquareRoot(vf_cuadrado)
    TextWindow.WriteLine("La Velocidad final (vf) es: " + vf + " m/s")
  ElseIf (k_txt = "?") Then
    HayIncognita = "Verdadero"
    E_cin_pot_ini = (0.5 * m_txt * vi_txt * vi_txt) + (m_txt * g * hi_txt)
    E_cin_pot_fin = (0.5 * m_txt * vf_txt * vf_txt) + (m_txt * g * hf_txt)
    W_f = f_txt * d_txt
    X_neto = (0.5 * xf_txt * xf_txt) - (0.5 * xi_txt * xi_txt)
    k = (E_cin_pot_ini - W_f - E_cin_pot_fin) / X_neto
    TextWindow.WriteLine("La Constante del resorte (k) es: " + k + " N/m")
  ElseIf (xi_txt = "?") Then
    HayIncognita = "Verdadero"
    E_fin = (0.5 * m_txt * vf_txt * vf_txt) + (m_txt * g * hf_txt) + (0.5 * k_txt * xf_txt * xf_txt)
    W_f = f_txt * d_txt
    E_ini_restante = (0.5 * m_txt * vi_txt * vi_txt) + (m_txt * g * hi_txt)
    xi_cuadrado = (E_fin + W_f - E_ini_restante) / (0.5 * k_txt)
    xi = Math.SquareRoot(xi_cuadrado)
    TextWindow.WriteLine("La deformación inicial del resorte (xi) es: " + xi + " m")
  ElseIf (xf_txt = "?") Then
    HayIncognita = "Verdadero"
    E_ini = (0.5 * m_txt * vi_txt * vi_txt) + (m_txt * g * hi_txt) + (0.5 * k_txt * xi_txt * xi_txt)
    W_f = f_txt * d_txt
    E_fin_restante = (0.5 * m_txt * vf_txt * vf_txt) + (m_txt * g * hf_txt)
    xf_cuadrado = (E_ini - W_f - E_fin_restante) / (0.5 * k_txt)
    xf = Math.SquareRoot(xf_cuadrado)
    TextWindow.WriteLine("La deformación final del resorte (xf) es: " + xf + " m")
  ElseIf (f_txt = "?") Then
    HayIncognita = "Verdadero"
    E_ini = (0.5 * m_txt * vi_txt * vi_txt) + (m_txt * g * hi_txt) + (0.5 * k_txt * xi_txt * xi_txt)
    E_fin = (0.5 * m_txt * vf_txt * vf_txt) + (m_txt * g * hf_txt) + (0.5 * k_txt * xf_txt * xf_txt)
    f = (E_ini - E_fin) / d_txt
    TextWindow.WriteLine("La Fuerza de fricción (f) es: " + f + " N")
  ElseIf (d_txt = "?") Then
    HayIncognita = "Verdadero"
    E_ini = (0.5 * m_txt * vi_txt * vi_txt) + (m_txt * g * hi_txt) + (0.5 * k_txt * xi_txt * xi_txt)
    E_fin = (0.5 * m_txt * vf_txt * vf_txt) + (m_txt * g * hf_txt) + (0.5 * k_txt * xf_txt * xf_txt)
    d = (E_ini - E_fin) / f_txt
    TextWindow.WriteLine("La Distancia de fricción (d) es: " + d + " metros")
  EndIf
  
  If (HayIncognita = "Falso") Then
    E_cinetica_ini = 0.5 * m_txt * vi_txt * vi_txt
    E_gravitatoria_ini = m_txt * g * hi_txt
    E_elastica_ini = 0.5 * k_txt * xi_txt * xi_txt
    E_mecanica_inicial = E_cinetica_ini + E_gravitatoria_ini + E_elastica_ini
    
    E_cinetica_fin = 0.5 * m_txt * vf_txt * vf_txt
    E_gravitatoria_fin = m_txt * g * hf_txt
    E_elastica_fin = 0.5 * k_txt * xf_txt * xf_txt
    E_mecanica_final = E_cinetica_fin + E_gravitatoria_fin + E_elastica_fin
    
    Trabajo_Friccion_Teorico = -1 * (f_txt * d_txt)
    Trabajo_No_Conservativo_Total = E_mecanica_final - E_mecanica_inicial
    
    TextWindow.WriteLine("¡No se detectaron incógnitas! Calculando balance energético:")
    TextWindow.WriteLine("")
    TextWindow.ForegroundColor = "Green"
    TextWindow.WriteLine("-> Energía Mecánica Inicial Total (Ei): " + E_mecanica_inicial + " Joules")
    TextWindow.WriteLine("   [Cinética: " + E_cinetica_ini + "J | Gravitatoria: " + E_gravitatoria_ini + "J | Elástica: " + E_elastica_ini + "J]")
    TextWindow.WriteLine("")
    TextWindow.ForegroundColor = "Red"
    TextWindow.WriteLine("-> Energía Mecánica Final Total (Ef): " + E_mecanica_final + " Joules")
    TextWindow.WriteLine("   [Cinética: " + E_cinetica_fin + "J | Gravitatoria: " + E_gravitatoria_fin + "J | Elástica: " + E_elastica_fin + "J]")
    TextWindow.WriteLine("")
    TextWindow.ForegroundColor = "Yellow"
    TextWindow.WriteLine("=> ENERGÍA NO CONSERVATIVA TOTAL (Trabajo neto disipado): " + Trabajo_No_Conservativo_Total + " Joules")
    TextWindow.WriteLine("   (Trabajo esperado por los valores de fricción ingresados: " + Trabajo_Friccion_Teorico + " Joules)")
  EndIf
  
  TextWindow.ForegroundColor = "White"
  TextWindow.WriteLine("")
  TextWindow.WriteLine("Presiona ENTER para volver al menú principal.")
  TextWindow.Read()
  TextWindow.Hide()
  GraphicsWindow.Show()
EndSub

