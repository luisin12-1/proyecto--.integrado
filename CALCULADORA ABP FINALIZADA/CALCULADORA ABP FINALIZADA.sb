' 6. MÓDULO CALCULADORA UNIVERSAL DE ECUACIONES
' =========================================================
Sub MostrarVentanaUniversal
  panelVisible = "Falso"
  puedeEscribir = "Falso"
  GraphicsWindow.Clear()
  GraphicsWindow.Title = "Calculadora Universal de Ecuaciones"
  GraphicsWindow.Width = 520
  GraphicsWindow.Height = 480
  GraphicsWindow.BackgroundColor = "White"
  GraphicsWindow.BrushColor = "DarkBlue"
  btnAbrirCalculadora = Controls.AddButton("Abrir Calculadora de Ecuaciones", 20, 20)
  Controls.SetSize(btnAbrirCalculadora, 250, 40)
  GraphicsWindow.BrushColor = "gray"
  btnVolverDeUniversal = Controls.AddButton("VOLVER", 290, 20)
  Controls.SetSize(btnVolverDeUniversal, 100, 40)
  Controls.ButtonClicked = AlHacerClicUniversal
EndSub

Sub AlHacerClicUniversal
  botonPresionado = Controls.LastClickedButton
  textoActual = Controls.GetTextBoxText(cajaTexto)
  If botonPresionado = btnVolverDeUniversal Then
    MostrarCalculadoraOriginal()
  EndIf
  If botonPresionado = btnAbrirCalculadora And panelVisible = "Falso" Then
    CrearPanelCalculadora()
    panelVisible = "Verdadero" 
  EndIf
  If botonPresionado = btnLimpiar Then
    Controls.SetTextBoxText(cajaTexto, "")
    puedeEscribir = "Falso" 
  EndIf
  If botonPresionado = btnActivar Then
    puedeEscribir = "Verdadero"
  EndIf
  If puedeEscribir = "Verdadero" Then
    If botonPresionado = btn0 Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "0")
    ElseIf botonPresionado = btn1 Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "1")
    ElseIf botonPresionado = btn2 Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "2")
    ElseIf botonPresionado = btn3 Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "3")
    ElseIf botonPresionado = btn4 Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "4")
    ElseIf botonPresionado = btn5 Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "5")
    ElseIf botonPresionado = btn6 Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "6")
    ElseIf botonPresionado = btn7 Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "7")
    ElseIf botonPresionado = btn8 Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "8")
    ElseIf botonPresionado = btn9 Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "9")
    ElseIf botonPresionado = btnX Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "x")
    ElseIf botonPresionado = btnMas Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "+")
    ElseIf botonPresionado = btnMenos Then 
      Controls.SetTextBoxText(cajaTexto, textoActual + "-")
    ElseIf botonPresionado = btnDiagonal Then 
      Controls.SetTextBoxText(cajaTexto, textoActual + "/")
    ElseIf botonPresionado = btnIgual Then
      Controls.SetTextBoxText(cajaTexto, textoActual + "=")
    EndIf
  EndIf
  If botonPresionado = btnResolver Then
    ecuacion = Text.ConvertToLowerCase(Controls.GetTextBoxText(cajaTexto))
    posIgual = Text.GetIndexOf(ecuacion, "=")
    If posIgual > 1 And Text.GetIndexOf(ecuacion, "x") > 0 Then
      miembroIzq = Text.GetSubText(ecuacion, 1, posIgual - 1)
      miembroDer = Text.GetSubTextToEnd(ecuacion, posIgual + 1)
      textoMiembro = miembroIzq
      ProcesarMiembro()
      acumX_Izq = acumX
      acumNum_Izq = acumNum
      textoMiembro = miembroDer
      ProcesarMiembro()
      acumX_Der = acumX
      acumNum_Der = acumNum
      A_lin = acumX_Izq - acumX_Der
      B_lin = acumNum_Der - acumNum_Izq
      If A_lin <> 0 Then
        resultadoXCrudo = B_lin / A_lin
        resultadoX = Math.Round(resultadoXCrudo * 100) / 100
        GraphicsWindow.ShowMessage("El valor de x es: " + resultadoX, "Resultado Exitoso")
      Else
        If B_lin = 0 Then
          GraphicsWindow.ShowMessage("La ecuación tiene infinitas soluciones.", "Resultado")
        Else
          GraphicsWindow.ShowMessage("La ecuación no tiene solución.", "Sin Solución")
        EndIf
      EndIf
    Else
      GraphicsWindow.ShowMessage("Formato inválido.", "Error de Formato")
    EndIf
    puedeEscribir = "Falso"
  EndIf
EndSub

Sub ProcesarMiembro
  acumX = 0
  acumNum = 0
  len = Text.GetLength(textoMiembro)
  posActual = 1
  While posActual <= len
    signo = 1
    char = Text.GetSubText(textoMiembro, posActual, 1)
    If char = "+" Then
      posActual = posActual + 1
    ElseIf char = "-" Then
      signo = -1
      posActual = posActual + 1
    EndIf
    inicioTermino = posActual
    Mientras = "Verdadero"
    While Mientras = "Verdadero" And posActual <= len
      c_char = Text.GetSubText(textoMiembro, posActual, 1)
      If c_char = "+" Or c_char = "-" Then
        Mientras = "Falso"
      Else
        posActual = posActual + 1
      EndIf
    EndWhile
    termino = Text.GetSubText(textoMiembro, inicioTermino, posActual - inicioTermino)
    tieneX = "Falso"
    If Text.GetIndexOf(termino, "x") > 0 Then
      tieneX = "Verdadero"
      posXEnTermino = Text.GetIndexOf(termino, "x")
      izqX = Text.GetSubText(termino, 1, posXEnTermino - 1)
      derX = Text.GetSubTextToEnd(termino, posXEnTermino + 1)
      termino = izqX + derX
    EndIf
    posD = Text.GetIndexOf(termino, "/")
    If posD > 0 Then
      numPart = Text.GetSubText(termino, 1, posD - 1)
      denPart = Text.GetSubTextToEnd(termino, posD + 1)
      If numPart = "" Then
        numPart = 1
      EndIf
      If denPart = 0 Or denPart = "" Then
        denPart = 1
      EndIf
      valorTermino = numPart / denPart
    Else
      If termino = "" Then
        valorTermino = 1
      Else
        valorTermino = termino + 0
      EndIf
    EndIf
    valorTermino = valorTermino * signo
    If tieneX = "Verdadero" Then
      acumX = acumX + valorTermino
    Else
      acumNum = acumNum + valorTermino
    EndIf
  EndWhile
EndSub

