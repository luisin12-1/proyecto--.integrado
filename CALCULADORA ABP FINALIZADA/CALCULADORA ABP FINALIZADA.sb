EndSub

Sub AlHacerClicEnergia
  BotonPresionado = Controls.LastClickedButton
  
  ' Botón Volver
  If BotonPresionado = btnVolverDeEnergia Then
    panelEnergiaIniciado = "Falso"
    MostrarCalculadoraOriginal()
  EndIf
  
  ' Gestión de Cambios de Modo de Despeje Algebraico
  If BotonPresionado = btnModoCalc Then
    ModoEnergia = "Calcular"
    Shapes.SetText(lblResultado, "Modo: Directo (Em)")
  ElseIf BotonPresionado = btnModoM Then
    ModoEnergia = "DespejarM"
    Shapes.SetText(lblResultado, "Modo: Buscar Masa (m)")
  ElseIf BotonPresionado = btnModoV Then
    ModoEnergia = "DespejarV"
    Shapes.SetText(lblResultado, "Modo: Buscar Vel. (v)")
  ElseIf BotonPresionado = btnModoK Then
    ModoEnergia = "DespejarK"
    Shapes.SetText(lblResultado, "Modo: Buscar Const. (k)")
  ElseIf BotonPresionado = btnModoX Then
    ModoEnergia = "DespejarX"
    Shapes.SetText(lblResultado, "Modo: Buscar Defor. (x)")
  EndIf
  
  ' Gestión de Enfoque de Casilla (Foco)
  If BotonPresionado = selEng Then
    CuadroActivo = txtEngObj
  ElseIf BotonPresionado = selMasa Then
    CuadroActivo = txtMasa
  ElseIf BotonPresionado = selVel Then
    CuadroActivo = txtVelocidad
  ElseIf BotonPresionado = selAlt Then
    CuadroActivo = txtAltura
  ElseIf BotonPresionado = selK Then
    CuadroActivo = txtK
  ElseIf BotonPresionado = selX Then
    CuadroActivo = txtX
  EndIf
  
  ' Entrada del Teclado Táctil
  TextoActual = Controls.GetTextBoxText(CuadroActivo)
  CaracterPresionado = ""
  
  If BotonPresionado = btn1 Then
    CaracterPresionado = "1"
  ElseIf BotonPresionado = btn2 Then
    CaracterPresionado = "2"
  ElseIf BotonPresionado = btn3 Then
    CaracterPresionado = "3"
  ElseIf BotonPresionado = btn4 Then
    CaracterPresionado = "4"
  ElseIf BotonPresionado = btn5 Then
    CaracterPresionado = "5"
  ElseIf BotonPresionado = btn6 Then
    CaracterPresionado = "6"
  ElseIf BotonPresionado = btn7 Then
    CaracterPresionado = "7"
  ElseIf BotonPresionado = btn8 Then
    CaracterPresionado = "8"
  ElseIf BotonPresionado = btn9 Then
    CaracterPresionado = "9"
  ElseIf BotonPresionado = btn0 Then
    CaracterPresionado = "0"
  ElseIf BotonPresionado = btnPunto Then
    CaracterPresionado = "."
  ElseIf BotonPresionado = btnMenos Then
    If TextoActual = "" Then
      CaracterPresionado = "-"
    EndIf
  ElseIf BotonPresionado = btnBorrar Then
    Controls.SetTextBoxText(CuadroActivo, "")
  EndIf
  
  If CaracterPresionado <> "" Then
    NuevoTexto = Text.Append(TextoActual, CaracterPresionado)
    Controls.SetTextBoxText(CuadroActivo, NuevoTexto)
  EndIf
  
  ' --- MOTOR DE RESOLUCIÓN FÍSICA Y CONSERVACIÓN ---
  If BotonPresionado = btnCalcular Then
    g = 9.81
    
    ' Obtención preventiva de todas las entradas del formulario
    E_objetivo = Controls.GetTextBoxText(txtEngObj)
    m = Controls.GetTextBoxText(txtMasa)
    v = Controls.GetTextBoxText(txtVelocidad)
    h = Controls.GetTextBoxText(txtAltura)
    k = Controls.GetTextBoxText(txtK)
    x = Controls.GetTextBoxText(txtX)
    
    ' Validaciones de nulos automáticos para evitar errores aritméticos
    If E_objetivo = "" Then
      E_objetivo = 0
    EndIf
    If m = "" Then
      m = 0
    EndIf
    If v = "" Then
      v = 0
    EndIf
    If h = "" Then
      h = 0
    EndIf
    If k = "" Then
      k = 0
    EndIf
    If x = "" Then
      x = 0
    EndIf

    ' Procesamiento según el modo de igualación activo
    If ModoEnergia = "Calcular" Then
      Ec = 0.5 * m * Math.Power(v, 2)
      Eg = m * g * h
      Ee = 0.5 * k * Math.Power(x, 2)
      Em = Ec + Eg + Ee
      
      ' Redondeos métricos limpios
      Ec = Math.Round(Ec * 100) / 100
      Eg = Math.Round(Eg * 100) / 100
      Ee = Math.Round(Ee * 100) / 100
      Em = Math.Round(Em * 100) / 100
      
      TextoResultado = "Ec: " + Ec + " J" + Text.GetCharacter(10)
      TextoResultado = TextoResultado + "Eg: " + Eg + " J" + Text.GetCharacter(10)
      TextoResultado = TextoResultado + "Ee: " + Ee + " J" + Text.GetCharacter(10)
      TextoResultado = TextoResultado + "Em Total: " + Em + " J"
      GraphicsWindow.ShowMessage(TextoResultado, "Cálculo de Energías Exitoso")
      
    ElseIf ModoEnergia = "DespejarM" Then
      ' E_total - Ee = m * (0.5*v^2 + g*h)
      Ee = 0.5 * k * Math.Power(x, 2)
      FactorMasa = (0.5 * Math.Power(v, 2)) + (g * h)
      
      If FactorMasa = 0 Then
        GraphicsWindow.ShowMessage("Imposible despejar: v y h son cero simultáneamente.", "Error Físico")
      Else
        m_despejada = (E_objetivo - Ee) / FactorMasa
        m_despejada = Math.Round(m_despejada * 100) / 100
        Controls.SetTextBoxText(txtMasa, m_despejada)
        GraphicsWindow.ShowMessage("Masa encontrada e insertada: " + m_despejada + " kg", "Conservación de Energía")
      EndIf
      
    ElseIf ModoEnergia = "DespejarV" Then
      Eg = m * g * h
      Ee = 0.5 * k * Math.Power(x, 2)
      ArgumentoV = (2 * (E_objetivo - Eg - Ee)) / m
      
      If m <= 0 Then
        GraphicsWindow.ShowMessage("Error: La masa debe ser mayor a 0 para buscar velocidad.", "Falta de Datos")
      ElseIf ArgumentoV < 0 Then
        GraphicsWindow.ShowMessage("Inconsistencia: La energía remanente es negativa para el estado.", "Error Físico")
      Else
        v_despejada = Math.SquareRoot(ArgumentoV)
        v_despejada = Math.Round(v_despejada * 100) / 100
        Controls.SetTextBoxText(txtVelocidad, v_despejada)
        GraphicsWindow.ShowMessage("Velocidad encontrada: " + v_despejada + " m/s", "Conservación de Energía")
      EndIf
      
    ElseIf ModoEnergia = "DespejarK" Then
      If x = 0 Then
        GraphicsWindow.ShowMessage("Error: La deformación X no puede ser 0 para despejar K.", "Falta de Datos")
      Else
        Ec = 0.5 * m * Math.Power(v, 2)
        Eg = m * g * h
        k_despejada = (2 * (E_objetivo - Ec - Eg)) / Math.Power(x, 2)
        k_despejada = Math.Round(k_despejada * 100) / 100
        Controls.SetTextBoxText(txtK, k_despejada)
        GraphicsWindow.ShowMessage("Constante elástica K: " + k_despejada + " N/m", "Conservación de Energía")
      EndIf
      
    ElseIf ModoEnergia = "DespejarX" Then
      If k <= 0 Then
        GraphicsWindow.ShowMessage("Error: Requiere constante K mayor a cero.", "Falta de Datos")
      Else
        Ec = 0.5 * m * Math.Power(v, 2)
        Eg = m * g * h
        ArgumentoX = (2 * (E_objetivo - Ec - Eg)) / k
        
        If ArgumentoX < 0 Then
          GraphicsWindow.ShowMessage("La energía del sistema ya está saturada por Ec y Eg.", "Límite Físico")
        Else
          x_despejada = Math.SquareRoot(ArgumentoX)
          x_despejada = Math.Round(x_despejada * 100) / 100
          Controls.SetTextBoxText(txtX, x_despejada)
          GraphicsWindow.ShowMessage("Compresión del resorte X: " + x_despejada + " m", "Conservación de Energía")
        EndIf
      EndIf
    EndIf
  EndIf
EndSub
