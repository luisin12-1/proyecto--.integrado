  GraphicsWindow.BrushColor = "Black"
  TxtA = Shapes.AddText("")
  TxtB = Shapes.AddText("")
  TxtC = Shapes.AddText("")
  TxtLinea1 = Shapes.AddText("Ingrese Coeficientes")
  TxtLinea2 = Shapes.AddText("")
  TxtLinea3 = Shapes.AddText("")
  Shapes.Move(TxtA, 50, 50)
  Shapes.Move(TxtB, 150, 50)
  Shapes.Move(TxtC, 250, 50)
  Shapes.Move(TxtLinea1, 50, 80)
  Shapes.Move(TxtLinea2, 50, 105)
  Shapes.Move(TxtLinea3, 50, 130)
  GraphicsWindow.BrushColor = "blue"
  BtnMinus = Controls.AddButton("-", 160, 370)
  BtnClear = Controls.AddButton("C", 240, 370)
  Controls.SetSize(BtnMinus, 60, 40)
  Controls.SetSize(BtnClear, 60, 40)
  GraphicsWindow.BrushColor = "#4A6572"
  BtnSiguiente = Controls.AddButton("Siguiente ( > )", 80, 170)
  Controls.SetSize(BtnSiguiente, 110, 35)
  GraphicsWindow.BrushColor = "#A45A52"
  BotonResolver = Controls.AddButton("RESOLVER", 210, 170)
  Controls.SetSize(BotonResolver, 110, 35)
  GraphicsWindow.BrushColor = "gray"
  BtnRegresar = Controls.AddButton("VOLVER", 20, 170)
  Controls.SetSize(BtnRegresar, 55, 35)
  GraphicsWindow.BrushColor = "blue"
  Num1 = Controls.AddButton("1", 40, 230)
  Num2 = Controls.AddButton("2", 110, 230)
  Num3 = Controls.AddButton("3", 180, 230)
  Num4 = Controls.AddButton("4", 40, 275)
  Num5 = Controls.AddButton("5", 110, 275)
  Num6 = Controls.AddButton("6", 180, 275)
  Num7 = Controls.AddButton("7", 40, 320)
  Num8 = Controls.AddButton("8", 110, 320)
  Num9 = Controls.AddButton("9", 180, 320)
  Num0 = Controls.AddButton("0", 40, 365)
  Controls.SetSize(Num1, 65, 40)
  Controls.SetSize(Num2, 65, 40)
  Controls.SetSize(Num3, 65, 40)
  Controls.SetSize(Num4, 65, 40)
  Controls.SetSize(Num5, 65, 40)
  Controls.SetSize(Num6, 65, 40)
  Controls.SetSize(Num7, 65, 40)
  Controls.SetSize(Num8, 65, 40)
  Controls.SetSize(Num9, 65, 40)
  Controls.SetSize(Num0, 110, 40)
  Controls.ButtonClicked = AlPresionarCuadratica
  ActualizarPantallaCuadratica()
EndSub

Sub AlPresionarCuadratica
  BotonDetectado = Controls.LastClickedButton
  TextoBoton = Controls.GetButtonCaption(BotonDetectado)
  If BotonDetectado = BtnRegresar Then
    MostrarCalculadoraOriginal()
  EndIf
  If BotonDetectado = BtnSiguiente Then
    If Foco = "a" Then
      Foco = "b"
    ElseIf Foco = "b" Then
      Foco = "c"
    Else
      Foco = "a"
    EndIf
    ActualizarPantallaCuadratica()
  EndIf
  If TextoBoton = "0" Or TextoBoton = "1" Or TextoBoton = "2" Or TextoBoton = "3" Or TextoBoton = "4" Or TextoBoton = "5" Or TextoBoton = "6" Or TextoBoton = "7" Or TextoBoton = "8" Or TextoBoton = "9" Or TextoBoton = "-" Then
    If Foco = "a" Then
      If Text.GetLength(ValA) < 5 Then
        ValA = Text.Append(ValA, TextoBoton)
      EndIf
    ElseIf Foco = "b" Then
      If Text.GetLength(ValB) < 5 Then
        ValB = Text.Append(ValB, TextoBoton)
      EndIf
    ElseIf Foco = "c" Then
      If Text.GetLength(ValC) < 5 Then
        ValC = Text.Append(ValC, TextoBoton)
      EndIf
    EndIf
    ActualizarPantallaCuadratica()
  EndIf
  If BotonDetectado = BtnClear Then
    If Foco = "a" Then
      ValA = ""
    ElseIf Foco = "b" Then
      ValB = ""
    ElseIf Foco = "c" Then
      ValC = ""
    EndIf
    ActualizarPantallaCuadratica()
    Shapes.SetText(TxtLinea2, "")
    Shapes.SetText(TxtLinea3, "")
  EndIf
  If BotonDetectado = BotonResolver Then
    a = ValA
    b = ValB
    c = ValC
    If a = "" Then
      a = 0
    EndIf
    If b = "" Then
      b = 0
    EndIf
    If c = "" Then
      c = 0
    EndIf
    Shapes.SetText(TxtLinea1, a + "x² + (" + b + ")x + (" + c + ") = 0")
    If a = 0 Then
      Shapes.SetText(TxtLinea2, "ERROR: 'a' no puede ser 0")
      Shapes.SetText(TxtLinea3, "")
    Else
      discriminante = (b * b) - (4 * a * c)
      If discriminante >= 0 Then
        raizDisc = Math.SquareRoot(discriminante)
        x1Crudo = (-b + raizDisc) / (2 * a)
        x2Crudo = (-b - raizDisc) / (2 * a)
        x1 = Math.Round(x1Crudo * 100) / 100
        x2 = Math.Round(x2Crudo * 100) / 100
        Shapes.SetText(TxtLinea2, "x1 = " + x1)
        Shapes.SetText(TxtLinea3, "x2 = " + x2)
      Else
        parteRealCruda = -b / (2 * a)
        parteImaginariaCruda = Math.SquareRoot(-discriminante) / (2 * a)
        parteReal = Math.Round(parteRealCruda * 100) / 100
        parteImaginaria = Math.Round(parteImaginariaCruda * 100) / 100
        Shapes.SetText(TxtLinea2, "x1 = " + parteReal + " + " + parteImaginaria + "i")
        Shapes.SetText(TxtLinea3, "x2 = " + parteReal + " - " + parteImaginaria + "i")
      EndIf
    EndIf
  EndIf
EndSub

Sub ActualizarPantallaCuadratica
  LabelA = " a : "
  LabelB = " b : "
  LabelC = " c : "
  If Foco = "a" Then
    LabelA = "[a]: "
  ElseIf Foco = "b" Then
    LabelB = "[b]: "
  ElseIf Foco = "c" Then
    LabelC = "[c]: "
  EndIf
  Shapes.SetText(TxtA, LabelA + ValA)
  Shapes.SetText(TxtB, LabelB + ValB)
  Shapes.SetText(TxtC, LabelC + ValC)
EndSub

