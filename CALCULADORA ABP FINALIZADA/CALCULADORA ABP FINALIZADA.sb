' =========================================================
' 7. MÓDULO SISTEMA DE ECUACIONES 2X2
' =========================================================
Sub InicializarCalculadoraSist2x2
  GraphicsWindow.Clear()
  GraphicsWindow.Title = "Calculadora 2x2 Interactive"
  GraphicsWindow.Width = 360
  GraphicsWindow.Height = 480
  GraphicsWindow.BackgroundColor = "#1E1E24"
  GraphicsWindow.BrushColor = "#2D3142"
  GraphicsWindow.FillRectangle(20, 20, 320, 80)
  GraphicsWindow.FontName = "Courier New"
  GraphicsWindow.FontBold = "True"
  GraphicsWindow.FontSize = 12
  GraphicsWindow.BrushColor = "#4F5D75"
  txtEcuaciones = Shapes.AddText("1) ax+by=c | dx+ey=f")
  Shapes.Move(txtEcuaciones, 30, 30)
  GraphicsWindow.FontSize = 18
  GraphicsWindow.BrushColor = "#FFFFFF"
  txtIngreso = Shapes.AddText("Ingrese a -> ")
  Shapes.Move(txtIngreso, 30, 60)
  GraphicsWindow.FontSize = 16
  GraphicsWindow.BrushColor = "#000000"
  b7 = Controls.AddButton("7", 20, 120)
  Controls.SetSize(b7, 65, 50)
  b8 = Controls.AddButton("8", 100, 120)
  Controls.SetSize(b8, 65, 50)
  b9 = Controls.AddButton("9", 180, 120)
  Controls.SetSize(b9, 65, 50)
  bC = Controls.AddButton("C", 260, 120)
  Controls.SetSize(bC, 80, 50)
  b4 = Controls.AddButton("4", 20, 185)
  Controls.SetSize(b4, 65, 50)
  b5 = Controls.AddButton("5", 100, 185)
  Controls.SetSize(b5, 65, 50)
  b6 = Controls.AddButton("6", 180, 185)
  Controls.SetSize(b6, 65, 50)
  bMenos = Controls.AddButton("-", 260, 185)
  Controls.SetSize(bMenos, 80, 50)
  b1 = Controls.AddButton("1", 20, 250)
  Controls.SetSize(b1, 65, 50)
  b2 = Controls.AddButton("2", 100, 250)
  Controls.SetSize(b2, 65, 50)
  b3 = Controls.AddButton("3", 180, 250)
  Controls.SetSize(b3, 65, 50)
  bPunto = Controls.AddButton(".", 260, 250)
  Controls.SetSize(bPunto, 80, 50)
  b0 = Controls.AddButton("0", 20, 315)
  Controls.SetSize(b0, 145, 50)
  bNext = Controls.AddButton("SIGUIENTE", 180, 315)
  Controls.SetSize(bNext, 160, 50)
  GraphicsWindow.BrushColor = "gray"
  bVolverSist = Controls.AddButton("VOLVER", 20, 380)
  Controls.SetSize(bVolverSist, 320, 45)
  Controls.ButtonClicked = AlPresionarBotonSist2x2
  ActualizarPantallaSist2x2()
EndSub

Sub AlPresionarBotonSist2x2
  ultimoBotonSist = Controls.LastClickedButton
  If ultimoBotonSist = bVolverSist Then
    MostrarCalculadoraOriginal()
  Else
    boton = Controls.GetButtonCaption(ultimoBotonSist)
    If boton = "C" Then
      paso = 1
      valorActual = ""
      sis_a = 0
      sis_b = 0
      sis_c = 0
      sis_d = 0
      sis_e = 0
      sis_f = 0
      Controls.SetButtonCaption(bNext, "SIGUIENTE")
      ActualizarPantallaSist2x2()
    ElseIf boton = "-" Then
      If Text.StartsWith(valorActual, "-") Then
        valorActual = Text.GetSubText(valorActual, 2, Text.GetLength(valorActual))
      Else
        valorActual = "-" + valorActual
      EndIf
      ActualizarPantallaSist2x2()
    ElseIf boton = "SIGUIENTE" Or boton = "RESOLVER" Then
      If valorActual = "" Or valorActual = "-" Then
        valorActual = "0"
      EndIf
      If paso = 1 Then
        sis_a = valorActual
      ElseIf paso = 2 Then
        sis_b = valorActual
      ElseIf paso = 3 Then
        sis_c = valorActual
      ElseIf paso = 4 Then
        sis_d = valorActual
      ElseIf paso = 5 Then
        sis_e = valorActual
      ElseIf paso = 6 Then
        sis_f = valorActual
      EndIf
      valorActual = ""
      paso = paso + 1
      ActualizarPantallaSist2x2()
      If paso = 7 Then
        ResolverSistema2x2()
      EndIf
    Else
      If boton <> "VOLVER" Then
        valorActual = Text.Append(valorActual, boton)
        ActualizarPantallaSist2x2()
      EndIf
    EndIf
  EndIf
EndSub

Sub ActualizarPantallaSist2x2
  eq1 = sis_a + "x + " + sis_b + "y = " + sis_c
  eq2 = sis_d + "x + " + sis_e + "y = " + sis_f
  Shapes.SetText(txtEcuaciones, "1) " + eq1 + " |2) " + eq2)
  If paso = 1 Then
    Shapes.SetText(txtIngreso, "Ingrese a -> " + valorActual)
  ElseIf paso = 2 Then
    Shapes.SetText(txtIngreso, "Ingrese b -> " + valorActual)
  ElseIf paso = 3 Then
    Shapes.SetText(txtIngreso, "Ingrese c -> " + valorActual)
  ElseIf paso = 4 Then
    Shapes.SetText(txtIngreso, "Ingrese d -> " + valorActual)
  ElseIf paso = 5 Then
    Shapes.SetText(txtIngreso, "Ingrese e -> " + valorActual)
  ElseIf paso = 6 Then
    Shapes.SetText(txtIngreso, "Ingrese f -> " + valorActual)
  Else
    Controls.SetButtonCaption(bNext, "RESOLVER")
  EndIf
EndSub

Sub ResolverSistema2x2
  determinanteSist = (sis_a * sis_e) - (sis_b * sis_d)
  If determinanteSist = 0 Then
    GraphicsWindow.ShowMessage("El sistema no tiene solución única", "Sin Solución")
  Else
    xCrudo = ((sis_c * sis_e) - (sis_b * sis_f)) / determinanteSist
    yCrudo = ((sis_a * sis_f) - (sis_c * sis_d)) / determinanteSist
    solX = Math.Round(xCrudo * 100) / 100
    solY = Math.Round(yCrudo * 100) / 100
    GraphicsWindow.ShowMessage("Solución encontrada:" + Text.GetCharacter(10) + "x = " + solX + Text.GetCharacter(10) + "y = " + solY, "Resultado")
  EndIf
  paso = 1
  valorActual = ""
  ActualizarPantallaSist2x2()
EndSub
