  btnModoM    = Controls.AddButton("Despejar Masa (m)", 500, 45)
  btnModoV    = Controls.AddButton("Despejar Vel. (v)", 330, 80)
  btnModoK    = Controls.AddButton("Despejar Const. (k)", 500, 80)
